# Google Gemini API Key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# LinkedIn OAuth Access Token (required for posting)
# How to get it:
#   1. Go to https://www.linkedin.com/developers/ — create or open your app
#   2. Under "Auth", add scopes: w_member_social, profile, email, openid
#   3. Use the OAuth 2.0 token generator in the developer portal to get a token
#   4. Token is valid for 60 days — store it in GitHub secrets as LINKEDIN_ACCESS_TOKEN
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# Your LinkedIn Person URN — auto-fetched on first run if blank
# Format: urn:li:person:XXXXXXXXXX
LINKEDIN_PERSON_URN=

# LinkedIn App credentials
LINKEDIN_CLIENT_ID=your_linkedin_client_id
PRIMARY_CLIENT_SECRET=your_linkedin_client_secret

# Topics to post about (comma-separated)
DEFAULT_TOPICS=AI,entrepreneurship,productivity,leadership,tech trends

# Posting schedule timezone
TIMEZONE=US/Eastern
